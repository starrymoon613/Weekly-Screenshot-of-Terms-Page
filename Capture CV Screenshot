
const { chromium } = require("playwright");

(async () => {
  const browser = await chromium.launch({ headless: true });
  const page = await browser.newPage();

  await page.goto("https://cv.hres.ca/en/terms/15", {
    waitUntil: "domcontentloaded",
  });

  // Wait longer + retry safety
  await page.waitForTimeout(5000);

  // Ensure table exists
  const tableExists = await page.locator("table").count();
  if (!tableExists) {
    throw new Error("Table not found on page");
  }

  // Set threshold (last 4 days)
  const threshold = new Date();
  threshold.setDate(threshold.getDate() - 4);

  await page.evaluate((thresholdStr) => {
    const threshold = new Date(thresholdStr);

    const table = document.querySelector("table");
    if (!table) return;

    const headers = Array.from(table.querySelectorAll("thead th"));

    const allowed = [
      "Code",
      "English display name",
      "French display name",
      "Source Status",
      "Last updated",
    ];

    // Map column names → indices
    const keepIndexes = [];
    headers.forEach((th, i) => {
      if (allowed.some(a => th.innerText.includes(a))) {
        keepIndexes.push(i);
      }
    });

    // Remove unwanted header columns
    headers.forEach((th, i) => {
      if (!keepIndexes.includes(i)) th.remove();
    });

    const rows = table.querySelectorAll("tbody tr");

    rows.forEach((row) => {
      const cells = Array.from(row.querySelectorAll("td"));

      // Remove unwanted columns
      cells.forEach((td, i) => {
        if (!keepIndexes.includes(i)) td.remove();
      });

      const updatedCell = row.querySelector("td:last-child");
      if (!updatedCell) {
        row.remove();
        return;
      }

      const text = updatedCell.innerText.trim();

      // Safer parsing
      const date = new Date(text);

      if (isNaN(date.getTime()) || date < threshold) {
        row.remove();
      }
    });
  }, threshold.toISOString());

  // Give time for DOM changes
  await page.waitForTimeout(2000);

  const table = page.locator("table");

  await table.screenshot({
    path: "screenshot.png",
  });

  await browser.close();
})();
